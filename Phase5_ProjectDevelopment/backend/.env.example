GROQ_API_KEY=your_groq_api_key_here
SECRET_KEY=your_secure_random_secret_key_here_change_in_production

# PostgreSQL connection string (Docker container must be running)
DATABASE_URL=postgresql+psycopg2://Smartbridge:Smartbridge123@localhost:5432/ResearchHub

# PubMed E-utilities API key (optional but recommended for higher rate limits)
# Get one free at: https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=your_pubmed_api_key_here

# arXiv API — no key required, publicly accessible
# Base URL: http://export.arxiv.org/api/query

ACCESS_TOKEN_EXPIRE_MINUTES=60
